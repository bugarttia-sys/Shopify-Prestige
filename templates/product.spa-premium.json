    "specs_tabs": {
      "type": "tabs",
      "blocks": {
        "tab_dimensions": {
          "type": "liquid",
          "settings": {
            "title": "Dimensions & Capacity",
            "liquid": "{% assign s = product.metafields.specs %}<div class=\"spa-specs-detail\"><table class=\"spa-specs-table spa-specs-table--wide\"><tr><td>Exterior Dimensions (L×W×H)</td><td>{{ s.length_cm }} × {{ s.width_cm }} × {{ s.height_cm }} cm</td></tr><tr><td>Water Capacity</td><td>{{ s.water_capacity_liters }} liters</td></tr><tr><td>Dry Weight</td><td>{{ s.dry_weight_kg }} kg</td></tr><tr><td>Filled Weight</td><td>{{ s.filled_weight_kg }} kg</td></tr><tr><td>Seating Capacity</td><td>{{ s.persons_capacity }} persons ({{ s.seats }} seats, {{ s.loungers }} loungers)</td></tr>{% if s.has_lounger.value %}<tr><td>Levitation Bed</td><td>Yes</td></tr>{% endif %}</table></div>",
            "open_on_mobile": false
          }
        },
        "tab_performance": {
          "type": "liquid",
          "settings": {
            "title": "Performance & Jets",
            "liquid": "{% assign s = product.metafields.specs %}<div class=\"spa-specs-detail\"><table class=\"spa-specs-table spa-specs-table--wide\"><tr><td>Total Jets</td><td>{{ s.total_jets }}</td></tr><tr><td>Hydrotherapy Jets</td><td>{{ s.hydro_jets }}</td></tr><tr><td>Air Jets</td><td>{{ s.air_jets }}</td></tr><tr><td>Massage Pumps</td><td>{{ s.massage_pumps }}</td></tr><tr><td>Filtration Pump</td><td>{{ s.filtration_pump }}</td></tr><tr><td>Air Pump</td><td>{{ s.air_pump }}</td></tr><tr><td>Electrical</td><td>{{ s.electrical }}</td></tr><tr><td>Pillows</td><td>{{ s.pillows }}</td></tr></table></div>",
            "open_on_mobile": false
          }
        },
        "tab_construction": {
          "type": "liquid",
          "settings": {
            "title": "Construction",
            "liquid": "{% assign c = product.metafields.construction %}<div class=\"spa-specs-detail\"><table class=\"spa-specs-table spa-specs-table--wide\"><tr><td>Shell Material</td><td>{{ c.shell_material }}</td></tr><tr><td>Frame</td><td>{{ c.frame }}</td></tr><tr><td>Insulation</td><td>{{ c.insulation }}</td></tr><tr><td>Heating System</td><td>{{ c.heating }}</td></tr><tr><td>Control System</td><td>{{ c.controls }}</td></tr></table>{% assign details = c.details.value %}{% if details %}<div class=\"spa-list-section\"><h4 class=\"spa-list-title\">Build Details</h4><ul class=\"spa-feature-list\">{% for item in details %}<li>{{ item }}</li>{% endfor %}</ul></div>{% endif %}{% assign filt = c.filtration.value %}{% if filt %}<div class=\"spa-list-section\"><h4 class=\"spa-list-title\">Filtration</h4><ul class=\"spa-feature-list\">{% for item in filt %}<li>{{ item }}</li>{% endfor %}</ul></div>{% endif %}{% assign wc = c.water_care.value %}{% if wc %}<div class=\"spa-list-section\"><h4 class=\"spa-list-title\">Water Care</h4><ul class=\"spa-feature-list\">{% for item in wc %}<li>{{ item }}</li>{% endfor %}</ul></div>{% endif %}{% assign light = c.lighting.value %}{% if light %}<div class=\"spa-list-section\"><h4 class=\"spa-list-title\">Lighting</h4><ul class=\"spa-feature-list\">{% for item in light %}<li>{{ item }}</li>{% endfor %}</ul></div>{% endif %}</div>",
            "open_on_mobile": false
          }
        },
        "tab_warranty": {
          "type": "liquid",
          "settings": {
            "title": "Warranty",
            "liquid": "{% assign w = product.metafields.warranty %}<div class=\"spa-specs-detail\"><table class=\"spa-specs-table spa-specs-table--wide\"><tr><td>Structure</td><td>{{ w.structure_years }} years</td></tr><tr><td>Surface</td><td>{{ w.surface_years }} years</td></tr><tr><td>Equipment</td><td>{{ w.equipment_years }} years</td></tr></table>{% assign certs = product.metafields.product.certifications.value %}{% if certs %}<div class=\"spa-list-section\"><h4 class=\"spa-list-title\">Certifications</h4><ul class=\"spa-feature-list\">{% for cert in certs %}<li>{{ cert }}</li>{% endfor %}</ul></div>{% endif %}</div>",
            "open_on_mobile": false
          }
        }
      },
      "block_order": [
        "tab_dimensions",
        "tab_performance",
        "tab_construction",
        "tab_warranty"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "separate_section_with_border": true,
        "subheading": "",
        "title": "Full Technical Specifications",
        "text_alignment": "center"
      }
