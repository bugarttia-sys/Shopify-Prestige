        "remove_vertical_spacing": false
      }
    },
    "hydrotherapy_detail": {
      "type": "image-with-text",
      "blocks": {
        "hydrotherapy_detail_liquid": {
          "type": "liquid",
          "settings": {
            "liquid": "<p class=\"spa-subtitle\" style=\"font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;opacity:0.6;margin-bottom:0.5rem\">Hydrotherapy System</p>\n<h2 style=\"font-size:clamp(1.5rem,3vw,2.5rem);font-weight:300;letter-spacing:-0.015em;line-height:1.15;margin-bottom:0.75rem\">Targeted relief. Total relaxation.</h2>\n<div class=\"prose\"><p>{{ product.metafields.specs.total_jets.value }} precision jets powered by {{ product.metafields.specs.massage_pumps.value }} massage pumps deliver targeted hydrotherapy to every seat.</p>{% assign comfort = product.metafields.features.comfort.value %}{% if comfort %}<ul class=\"spa-feature-list--inline\">{% for c in comfort %}<li>{{ c }}</li>{% endfor %}</ul>{% endif %}</div>"
          }
        }
      },
      "block_order": [
        "hydrotherapy_detail_liquid"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "separate_section_with_border": true,
        "image": "{{ product.featured_image }}",
        "reveal_on_scroll": true,
        "image_position": "start",
        "content_width": "sm",
        "remove_vertical_spacing": true
      }
    },
    "energy_detail": {
      "type": "image-with-text",
      "blocks": {
        "energy_detail_liquid": {
          "type": "liquid",
          "settings": {
            "liquid": "<p class=\"spa-subtitle\" style=\"font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;opacity:0.6;margin-bottom:0.5rem\">Energy Management</p>\n<h2 style=\"font-size:clamp(1.5rem,3vw,2.5rem);font-weight:300;letter-spacing:-0.015em;line-height:1.15;margin-bottom:0.75rem\">Intelligent insulation. Minimal running costs.</h2>\n<div class=\"prose\">{% assign nrg = product.metafields.features.energy.value %}{% if nrg %}<ul class=\"spa-feature-list--inline\">{% for e in nrg %}<li>{{ e }}</li>{% endfor %}</ul>{% endif %}{% assign opt = product.metafields.features.optional.value %}{% if opt %}<p class=\"spa-subtitle\" style=\"margin-top:1rem\">Optional upgrades:</p><ul class=\"spa-feature-list--inline\">{% for o in opt %}<li>{{ o }}</li>{% endfor %}</ul>{% endif %}</div>"
          }
        }
      },
      "block_order": [
        "energy_detail_liquid"
      ],
