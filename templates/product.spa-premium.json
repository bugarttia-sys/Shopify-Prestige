    "entertainment_detail": {
      "type": "image-with-text",
      "blocks": {
        "entertainment_detail_liquid": {
          "type": "liquid",
          "settings": {
            "liquid": "<p class=\"spa-subtitle\" style=\"font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;opacity:0.6;margin-bottom:0.5rem\">Entertainment & Ambiance</p>\n<h2 style=\"font-size:clamp(1.5rem,3vw,2.5rem);font-weight:300;letter-spacing:-0.015em;line-height:1.15;margin-bottom:0.75rem\">Set the mood. Set the scene.</h2>\n<div class=\"prose\">{% assign ent = product.metafields.features.entertainment.value %}{% assign lt = product.metafields.features.lighting.value %}{% assign cn = product.metafields.features.connectivity.value %}{% if lt %}<ul class=\"spa-feature-list--inline\">{% for l in lt %}<li>{{ l }}</li>{% endfor %}</ul>{% endif %}{% if ent %}<ul class=\"spa-feature-list--inline\">{% for e in ent %}<li>{{ e }}</li>{% endfor %}</ul>{% endif %}{% if cn %}<ul class=\"spa-feature-list--inline\">{% for c in cn %}<li>{{ c }}</li>{% endfor %}</ul>{% endif %}</div>"
          }
        }
