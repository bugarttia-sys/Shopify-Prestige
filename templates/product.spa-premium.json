            "liquid": "{% assign props = product.metafields.features.proprietary.value %}{% if props %}<div class=\"spa-therapy-grid\">{% for p in props %}<div class=\"spa-therapy-pill spa-therapy-pill--gold\">{{ p }}</div>{% endfor %}</div>{% endif %}"
