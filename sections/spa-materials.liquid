{%- comment -%}
  SPA MATERIALS — Construction & materials showcase
  Anchored as #spa-materials
  Dark-themed icon grid + detail list
  Uses: product.metafields.construction.*
        product.metafields.product.made_in
{%- endcomment -%}

{%- liquid
  assign c = product.metafields.construction
  assign made_in = product.metafields.product.made_in.value | default: 'The Netherlands'
  assign details = c.details.value
  assign filtration = c.filtration.value
  assign water_care = c.water_care.value
  assign light_list = c.lighting.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-mat {
    background: var(--gms-charcoal, #1A1A1A);
    color: #fff;
  }

  #shopify-section-{{ section.id }} .spa-mat__header {
    text-align: center;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 4vw, 3rem);
  }

  #shopify-section-{{ section.id }} .spa-mat__eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-mat__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 200;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-mat__heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--gms-gold, #C68A1F);
    margin: 1.25rem auto 0;
  }

  #shopify-section-{{ section.id }} .spa-mat__origin {
    font-size: 0.85rem;
    font-weight: 300;
    opacity: 0.5;
    margin-top: 1rem;
  }

  /* ── Icon grid ── */
  #shopify-section-{{ section.id }} .spa-mat__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
  }

  #shopify-section-{{ section.id }} .spa-mat__item {
    text-align: center;
    padding: clamp(1.5rem, 3vw, 2.5rem) 1rem;
    border-right: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  #shopify-section-{{ section.id }} .spa-mat__item:nth-child(5n) {
    border-right: none;
  }

  #shopify-section-{{ section.id }} .spa-mat__item-icon {
    opacity: 0.3;
    margin-bottom: 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-mat__item-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.4;
    margin: 0 0 0.3rem;
  }

  #shopify-section-{{ section.id }} .spa-mat__item-value {
    font-size: 0.82rem;
    font-weight: 400;
    line-height: 1.4;
    opacity: 0.8;
  }

  /* ── Detail lists ── */
  #shopify-section-{{ section.id }} .spa-mat__details {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.25rem, 4vw, 3rem) clamp(4rem, 6vw, 6rem);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2.5rem;
  }

  #shopify-section-{{ section.id }} .spa-mat__detail-group h4 {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.35;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  #shopify-section-{{ section.id }} .spa-mat__detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-mat__detail-list li {
    position: relative;
    padding: 0.3rem 0 0.3rem 1.1rem;
    font-size: 0.8rem;
    font-weight: 300;
    line-height: 1.5;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .spa-mat__detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gms-gold, #C68A1F);
    opacity: 0.6;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-mat__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    #shopify-section-{{ section.id }} .spa-mat__item:nth-child(5n) {
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    #shopify-section-{{ section.id }} .spa-mat__item:nth-child(2n) {
      border-right: none;
    }
  }
</style>

<section class="spa-mat" id="spa-materials" aria-label="Materials and construction">
  <div class="spa-mat__header">
    <p class="spa-mat__eyebrow">{{ section.settings.eyebrow | default: 'Construction' }}</p>
    <h2 class="spa-mat__heading">{{ section.settings.heading | default: 'Built to endure.' }}</h2>
    <p class="spa-mat__origin">Handcrafted in {{ made_in }}</p>
  </div>

  {%- if c.shell_material != blank -%}
    <div class="spa-mat__grid">
      <div class="spa-mat__item">
        <div class="spa-mat__item-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg></div>
        <p class="spa-mat__item-label">Shell</p>
        <p class="spa-mat__item-value">{{ c.shell_material }}</p>
      </div>
      <div class="spa-mat__item">
        <div class="spa-mat__item-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg></div>
        <p class="spa-mat__item-label">Frame</p>
        <p class="spa-mat__item-value">{{ c.frame }}</p>
      </div>
      <div class="spa-mat__item">
        <div class="spa-mat__item-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <p class="spa-mat__item-label">Heating</p>
        <p class="spa-mat__item-value">{{ c.heating }}</p>
      </div>
      <div class="spa-mat__item">
        <div class="spa-mat__item-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M3 3v18h18"/><path d="M7 16l4-4 4 4 5-5"/></svg></div>
        <p class="spa-mat__item-label">Insulation</p>
        <p class="spa-mat__item-value">{{ c.insulation }}</p>
      </div>
      <div class="spa-mat__item">
        <div class="spa-mat__item-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
        <p class="spa-mat__item-label">Controls</p>
        <p class="spa-mat__item-value">{{ c.controls }}</p>
      </div>
    </div>
  {%- endif -%}

  <div class="spa-mat__details">
    {%- if details -%}
      <div class="spa-mat__detail-group">
        <h4>Build Details</h4>
        <ul class="spa-mat__detail-list">
          {%- for item in details -%}<li>{{ item }}</li>{%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
    {%- if filtration -%}
      <div class="spa-mat__detail-group">
        <h4>Filtration</h4>
        <ul class="spa-mat__detail-list">
          {%- for item in filtration -%}<li>{{ item }}</li>{%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
    {%- if water_care -%}
      <div class="spa-mat__detail-group">
        <h4>Water Care</h4>
        <ul class="spa-mat__detail-list">
          {%- for item in water_care -%}<li>{{ item }}</li>{%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
    {%- if light_list -%}
      <div class="spa-mat__detail-group">
        <h4>Lighting</h4>
        <ul class="spa-mat__detail-list">
          {%- for item in light_list -%}<li>{{ item }}</li>{%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Spa Materials",
  "tag": "section",
  "class": "shopify-section--spa-materials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Construction"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built to endure."
    }
  ],
  "presets": [
    {
      "name": "Spa Materials"
    }
  ]
}
{% endschema %}
