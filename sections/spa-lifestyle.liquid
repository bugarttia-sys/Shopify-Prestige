{%- comment -%}
  SPA LIFESTYLE — Cinematic gallery with alternating dark/light themed blocks
  Premium storytelling: centered header with accent line → full-bleed image → split text+image
  Uses: product.metafields.content.design_story / collection_story
        product.metafields.media.design_story / interior
        product.metafields.custom.lifestyle_heading
        product.metafields.content.highlights (json)
{%- endcomment -%}

{%- liquid
  assign lifestyle_heading = product.metafields.custom.lifestyle_heading.value | default: section.settings.heading
  assign design_story = product.metafields.content.design_story.value
  assign design_img = product.metafields.media.design_story.value | default: product.featured_image
  assign interior_img = product.metafields.media.interior.value | default: product.featured_image
  assign highlights = product.metafields.content.highlights.value
-%}

<style>
  /* ── INTRO BLOCK (light theme, centered) ── */
  #shopify-section-{{ section.id }} .spa-life {
    --section-bg: #f7f7f7;
    --section-text: var(--gms-charcoal, #1A1A1A);
  }

  #shopify-section-{{ section.id }} .spa-life__intro {
    background: var(--section-bg);
    color: var(--section-text);
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 4vw, 3rem);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .spa-life__eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-life__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 200;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 auto 1.5rem;
    max-width: 16ch;
  }

  /* Accent underline (BMW-inspired structural element) */
  #shopify-section-{{ section.id }} .spa-life__heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--gms-gold, #C68A1F);
    margin: 1.25rem auto 0;
  }

  #shopify-section-{{ section.id }} .spa-life__intro-body {
    font-size: clamp(0.9rem, 1.15vw, 1.05rem);
    font-weight: 300;
    line-height: 1.8;
    opacity: 0.65;
    max-width: 52ch;
    margin: 0 auto;
  }

  /* ── FULL-BLEED IMAGE ── */
  #shopify-section-{{ section.id }} .spa-life__fullbleed {
    position: relative;
    height: clamp(40vh, 55vw, 70vh);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .spa-life__fullbleed img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── SPLIT BLOCK (dark theme) ── */
  #shopify-section-{{ section.id }} .spa-life__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }

  #shopify-section-{{ section.id }} .spa-life__split--reverse {
    direction: rtl;
  }

  #shopify-section-{{ section.id }} .spa-life__split--reverse > * {
    direction: ltr;
  }

  #shopify-section-{{ section.id }} .spa-life__split-media {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .spa-life__split-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #shopify-section-{{ section.id }} .spa-life__split-media:hover img {
    transform: scale(1.03);
  }

  #shopify-section-{{ section.id }} .spa-life__split-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 5vw, 5rem) clamp(2rem, 4vw, 4rem);
    background: var(--gms-charcoal, #1A1A1A);
    color: #fff;
  }

  #shopify-section-{{ section.id }} .spa-life__split-content--light {
    background: #f7f7f7;
    color: var(--gms-charcoal, #1A1A1A);
  }

  #shopify-section-{{ section.id }} .spa-life__split-eyebrow {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-life__split-heading {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 200;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 1rem;
    max-width: 18ch;
  }

  #shopify-section-{{ section.id }} .spa-life__split-body {
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    font-weight: 300;
    line-height: 1.8;
    opacity: 0.7;
    max-width: 42ch;
  }

  #shopify-section-{{ section.id }} .spa-life__split-body p {
    margin: 0;
  }

  /* ── HIGHLIGHTS STRIP ── */
  #shopify-section-{{ section.id }} .spa-life__highlights {
    background: var(--gms-charcoal, #1A1A1A);
    color: #fff;
    padding: clamp(3rem, 5vw, 5rem) clamp(1.25rem, 4vw, 3rem);
  }

  #shopify-section-{{ section.id }} .spa-life__highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
    max-width: 1200px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .spa-life__highlight {
    text-align: center;
    padding: 1rem 0;
  }

  #shopify-section-{{ section.id }} .spa-life__highlight-icon {
    opacity: 0.4;
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-life__highlight-title {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin: 0 0 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-life__highlight-body {
    font-size: 0.8rem;
    font-weight: 300;
    line-height: 1.7;
    opacity: 0.5;
    max-width: 28ch;
    margin: 0 auto;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-life__split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    #shopify-section-{{ section.id }} .spa-life__split--reverse {
      direction: ltr;
    }

    #shopify-section-{{ section.id }} .spa-life__split-media {
      height: 50vw;
      min-height: 200px;
    }

    #shopify-section-{{ section.id }} .spa-life__highlights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="spa-life" id="spa-lifestyle">
  {%- comment -%} Intro block — centered header {%- endcomment -%}
  <div class="spa-life__intro">
    <p class="spa-life__eyebrow">{{ section.settings.eyebrow | default: 'The Experience' }}</p>
    <h2 class="spa-life__heading">{{ lifestyle_heading | default: 'Designed around the way you live.' }}</h2>
    {%- if design_story != blank -%}
      <p class="spa-life__intro-body">{{ design_story | truncatewords: 40 }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Full-bleed hero image {%- endcomment -%}
  <div class="spa-life__fullbleed">
    {%- if design_img != blank -%}
      {{ design_img | image_url: width: 2400 | image_tag: loading: 'lazy', sizes: '100vw', widths: '600,900,1200,1600,2000,2400', alt: product.title | append: ' lifestyle' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
    {%- endif -%}
  </div>

  {%- comment -%} Split block — dark bg, text left, image right {%- endcomment -%}
  <div class="spa-life__split">
    <div class="spa-life__split-content">
      <p class="spa-life__split-eyebrow">Design Philosophy</p>
      <h3 class="spa-life__split-heading">{{ section.settings.design_heading | default: 'Every curve has a purpose.' }}</h3>
      <div class="spa-life__split-body">
        {%- if design_story != blank -%}
          <p>{{ design_story | truncatewords: 50 }}</p>
        {%- else -%}
          <p>Sculptural forms meet ergonomic precision. Each contour is shaped around the human body, delivering targeted hydrotherapy to every pressure point.</p>
        {%- endif -%}
      </div>
    </div>
    <div class="spa-life__split-media">
      {%- if interior_img != blank -%}
        {{ interior_img | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000,1200', alt: product.title | append: ' interior' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Split block reversed — light bg, image left, text right {%- endcomment -%}
  <div class="spa-life__split spa-life__split--reverse">
    <div class="spa-life__split-content spa-life__split-content--light">
      <p class="spa-life__split-eyebrow">Interior Design</p>
      <h3 class="spa-life__split-heading">{{ section.settings.interior_heading | default: 'Sculpted for the human body.' }}</h3>
      <div class="spa-life__split-body">
        <p>{{ section.settings.interior_body | default: 'Every seat is contoured at a different depth, with jets positioned by physiotherapists to target specific muscle groups.' }}</p>
      </div>
    </div>
    <div class="spa-life__split-media">
      {%- if design_img != blank -%}
        {{ design_img | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000,1200', alt: product.title | append: ' design detail' }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Highlights strip — dark theme {%- endcomment -%}
  {%- if highlights != blank and highlights.size > 0 -%}
    <div class="spa-life__highlights">
      <div class="spa-life__highlights-grid">
        {%- for h in highlights -%}
          <div class="spa-life__highlight">
            <div class="spa-life__highlight-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            </div>
            <h4 class="spa-life__highlight-title">{{ h.title }}</h4>
            <p class="spa-life__highlight-body">{{ h.body }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Spa Lifestyle",
  "tag": "section",
  "class": "shopify-section--spa-lifestyle",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Experience"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Designed around the way you live."
    },
    {
      "type": "text",
      "id": "design_heading",
      "label": "Design block heading",
      "default": "Every curve has a purpose."
    },
    {
      "type": "text",
      "id": "interior_heading",
      "label": "Interior block heading",
      "default": "Sculpted for the human body."
    },
    {
      "type": "textarea",
      "id": "interior_body",
      "label": "Interior block body",
      "default": "Every seat is contoured at a different depth, with jets positioned by physiotherapists to target specific muscle groups."
    }
  ],
  "presets": [
    {
      "name": "Spa Lifestyle"
    }
  ]
}
{% endschema %}
