{%- comment -%}
  SPA LIFESTYLE — Alternating image+text storytelling blocks
  Uses: product.metafields.content.design_story
        product.metafields.content.technology_story
        product.metafields.media.design_story
        product.metafields.media.lifestyle_*
        product.metafields.custom.lifestyle_heading
        product.metafields.content.highlights (json list)
{%- endcomment -%}

{%- liquid
  assign lifestyle_heading = product.metafields.custom.lifestyle_heading.value | default: section.settings.heading
  assign design_story = product.metafields.content.design_story.value
  assign design_img = product.metafields.media.design_story.value | default: product.featured_image
  assign highlights = product.metafields.content.highlights.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-lifestyle {
    padding: clamp(3rem, 5vw, 5rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__container {
    max-width: var(--container-lg-max-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--container-gutter, 1.25rem);
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__heading {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin: 0;
  }

  /* --- Story block: image + text side-by-side --- */
  #shopify-section-{{ section.id }} .spa-lifestyle__story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__story--reverse {
    direction: rtl;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__story--reverse > * {
    direction: ltr;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__media img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--gms-radius, 2px);
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__text {
    max-width: 480px;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__text-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__text h3 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 300;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__text p {
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1.7;
    opacity: 0.82;
    max-width: 46ch;
    margin: 0;
  }

  /* --- Highlights grid --- */
  #shopify-section-{{ section.id }} .spa-lifestyle__highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--gms-border, rgba(0,0,0,0.06));
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__highlight {
    text-align: center;
    padding: 1.5rem 1rem;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__highlight-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__highlight-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-lifestyle__highlight-body {
    font-size: 0.85rem;
    line-height: 1.65;
    opacity: 0.7;
    max-width: 36ch;
    margin-inline: auto;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-lifestyle__story {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    #shopify-section-{{ section.id }} .spa-lifestyle__story--reverse {
      direction: ltr;
    }

    #shopify-section-{{ section.id }} .spa-lifestyle__highlights {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>

<section class="spa-lifestyle" aria-label="Lifestyle and design">
  <div class="spa-lifestyle__container">

    {%- if lifestyle_heading != blank -%}
      <div class="spa-lifestyle__header">
        <p class="spa-lifestyle__label">{{ section.settings.label | default: 'Design Philosophy' }}</p>
        <h2 class="spa-lifestyle__heading">{{ lifestyle_heading }}</h2>
      </div>
    {%- endif -%}

    {%- comment -%} Design story block {%- endcomment -%}
    <div class="spa-lifestyle__story">
      <div class="spa-lifestyle__media">
        {%- if design_img != blank -%}
          {{ design_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000,1200', alt: product.title | append: ' design' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="spa-lifestyle__text">
        <p class="spa-lifestyle__text-label">Design Philosophy</p>
        <h3>{{ section.settings.design_heading | default: 'Every curve has a purpose.' }}</h3>
        {%- if design_story != blank -%}
          <p>{{ design_story | truncatewords: 60 }}</p>
        {%- else -%}
          <p>Sculptural forms meet ergonomic precision. Each contour is shaped around the human body — delivering targeted hydrotherapy to every pressure point.</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Interior story block (reversed) {%- endcomment -%}
    {%- assign interior_img = product.metafields.media.interior.value | default: product.featured_image -%}
    <div class="spa-lifestyle__story spa-lifestyle__story--reverse">
      <div class="spa-lifestyle__media">
        {%- if interior_img != blank -%}
          {{ interior_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000,1200', alt: product.title | append: ' interior' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="spa-lifestyle__text">
        <p class="spa-lifestyle__text-label">Interior Design</p>
        <h3>{{ section.settings.interior_heading | default: 'Sculpted for the human body.' }}</h3>
        <p>{{ section.settings.interior_body | default: 'Every seat is contoured at a different depth, with jets positioned by physiotherapists to target specific muscle groups.' }}</p>
      </div>
    </div>

    {%- comment -%} Highlights grid {%- endcomment -%}
    {%- if highlights != blank and highlights.size > 0 -%}
      <div class="spa-lifestyle__highlights">
        {%- for h in highlights -%}
          <div class="spa-lifestyle__highlight">
            <div class="spa-lifestyle__highlight-icon">
              {%- case h.icon -%}
                {%- when 'levitation-bed' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 18h18M5 14c0-2 1-4 7-4s7 2 7 4"/><circle cx="12" cy="7" r="2"/></svg>
                {%- when 'jets' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-10-10h4m12 0h4m-3.5-7.5l-3 3m-6 6l-3 3m0-12l3 3m6 6l3 3"/></svg>
                {%- when 'therapies' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01M15 9h.01"/></svg>
                {%- when 'energy' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                {%- when 'water' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                {%- when 'entertainment' -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                {%- else -%}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01z"/></svg>
              {%- endcase -%}
            </div>
            <h4 class="spa-lifestyle__highlight-title">{{ h.title }}</h4>
            <p class="spa-lifestyle__highlight-body">{{ h.body }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Spa Lifestyle",
  "tag": "section",
  "class": "shopify-section--spa-lifestyle",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Design Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Every curve has a purpose."
    },
    {
      "type": "text",
      "id": "design_heading",
      "label": "Design block heading",
      "default": "Every curve has a purpose."
    },
    {
      "type": "text",
      "id": "interior_heading",
      "label": "Interior block heading",
      "default": "Sculpted for the human body."
    },
    {
      "type": "textarea",
      "id": "interior_body",
      "label": "Interior block body",
      "default": "Every seat is contoured at a different depth, with jets positioned by physiotherapists to target specific muscle groups."
    }
  ],
  "presets": [
    {
      "name": "Spa Lifestyle"
    }
  ]
}
{% endschema %}
