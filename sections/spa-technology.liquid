{%- comment -%}
  SPA TECHNOLOGY — Advanced technology with tabbed spec interface
  Anchored as #spa-technology
  Uses: product.metafields.specs.* / construction.* / warranty.* / features.proprietary
        product.metafields.content.technology_story
        product.metafields.media.technology
{%- endcomment -%}

{%- liquid
  assign tech_story = product.metafields.content.technology_story.value
  assign tech_img = product.metafields.media.technology.value | default: product.featured_image
  assign proprietary = product.metafields.features.proprietary.value
  assign s = product.metafields.specs
  assign c = product.metafields.construction
  assign w = product.metafields.warranty
  assign certs = product.metafields.product.certifications.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-tech {
    background: #f7f7f7;
    color: var(--gms-charcoal, #1A1A1A);
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .spa-tech__header {
    text-align: center;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 4vw, 3rem);
  }

  #shopify-section-{{ section.id }} .spa-tech__eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 200;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 auto;
    max-width: 18ch;
  }

  #shopify-section-{{ section.id }} .spa-tech__heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--gms-gold, #C68A1F);
    margin: 1.25rem auto 0;
  }

  #shopify-section-{{ section.id }} .spa-tech__intro {
    font-size: clamp(0.9rem, 1.1vw, 1rem);
    font-weight: 300;
    line-height: 1.8;
    opacity: 0.6;
    max-width: 50ch;
    margin: 1.25rem auto 0;
    text-align: center;
  }

  /* ── Proprietary pills ── */
  #shopify-section-{{ section.id }} .spa-tech__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    list-style: none;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 4vw, 3rem);
    margin: 0 auto;
    max-width: 900px;
  }

  #shopify-section-{{ section.id }} .spa-tech__pill {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.45em 1.1em;
    border: 1px solid var(--gms-gold, #C68A1F);
    color: var(--gms-gold, #C68A1F);
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .spa-tech__pill:hover {
    background: var(--gms-gold, #C68A1F);
    color: #fff;
  }

  /* ── Tabbed specs ── */
  #shopify-section-{{ section.id }} .spa-tech__specs {
    max-width: 1000px;
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 4rem) clamp(1.25rem, 4vw, 3rem) clamp(4rem, 6vw, 6rem);
  }

  #shopify-section-{{ section.id }} .spa-tech__tabs {
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    margin-bottom: 2rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .spa-tech__tabs::-webkit-scrollbar { display: none; }

  #shopify-section-{{ section.id }} .spa-tech__tab {
    padding: 0.9rem 1.5rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    opacity: 0.35;
    transition: all 0.3s ease;
    white-space: nowrap;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .spa-tech__tab:hover { opacity: 0.7; }

  #shopify-section-{{ section.id }} .spa-tech__tab[aria-selected="true"] {
    opacity: 1;
    border-bottom-color: var(--gms-gold, #C68A1F);
  }

  #shopify-section-{{ section.id }} .spa-tech__panel {
    display: none;
    max-width: 640px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .spa-tech__panel[aria-hidden="false"] { display: block; }

  #shopify-section-{{ section.id }} .spa-tech__table {
    width: 100%;
    border-collapse: collapse;
  }

  #shopify-section-{{ section.id }} .spa-tech__table tr {
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  #shopify-section-{{ section.id }} .spa-tech__table td {
    padding: 0.7rem 0;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .spa-tech__table td:first-child {
    font-weight: 300;
    opacity: 0.5;
    width: 50%;
    padding-right: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__table td:last-child {
    text-align: right;
    font-weight: 500;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-tech__tabs {
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .spa-tech__tab {
      padding: 0.75rem 1rem;
      font-size: 0.6rem;
    }
  }
</style>

<section class="spa-tech" id="spa-technology" aria-label="Technology and specifications">
  <div class="spa-tech__header">
    <p class="spa-tech__eyebrow">{{ section.settings.eyebrow | default: 'Technology' }}</p>
    <h2 class="spa-tech__heading">{{ section.settings.heading | default: 'Engineered without compromise.' }}</h2>
    {%- if tech_story != blank -%}
      <p class="spa-tech__intro">{{ tech_story | truncatewords: 35 }}</p>
    {%- endif -%}
  </div>

  {%- if proprietary != blank and proprietary.size > 0 -%}
    <ul class="spa-tech__pills">
      {%- for p in proprietary -%}
        <li class="spa-tech__pill">{{ p }}</li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  <div class="spa-tech__specs">
    <div class="spa-tech__tabs" role="tablist">
      <button class="spa-tech__tab" role="tab" aria-selected="true" aria-controls="tech-dim-{{ section.id }}" id="ttab-dim-{{ section.id }}" tabindex="0">Dimensions</button>
      <button class="spa-tech__tab" role="tab" aria-selected="false" aria-controls="tech-perf-{{ section.id }}" id="ttab-perf-{{ section.id }}" tabindex="-1">Performance</button>
      <button class="spa-tech__tab" role="tab" aria-selected="false" aria-controls="tech-build-{{ section.id }}" id="ttab-build-{{ section.id }}" tabindex="-1">Construction</button>
      <button class="spa-tech__tab" role="tab" aria-selected="false" aria-controls="tech-warr-{{ section.id }}" id="ttab-warr-{{ section.id }}" tabindex="-1">Warranty</button>
    </div>

    <div class="spa-tech__panel" id="tech-dim-{{ section.id }}" role="tabpanel" aria-labelledby="ttab-dim-{{ section.id }}" aria-hidden="false">
      <table class="spa-tech__table">
        <tr><td>Dimensions (L&times;W&times;H)</td><td>{{ s.length_cm }} &times; {{ s.width_cm }} &times; {{ s.height_cm }} cm</td></tr>
        <tr><td>Water Capacity</td><td>{{ s.water_capacity_liters }} litres</td></tr>
        <tr><td>Dry Weight</td><td>{{ s.dry_weight_kg }} kg</td></tr>
        <tr><td>Filled Weight</td><td>{{ s.filled_weight_kg }} kg</td></tr>
        <tr><td>Seating</td><td>{{ s.persons_capacity }} persons ({{ s.seats }} seats, {{ s.loungers }} loungers)</td></tr>
      </table>
    </div>

    <div class="spa-tech__panel" id="tech-perf-{{ section.id }}" role="tabpanel" aria-labelledby="ttab-perf-{{ section.id }}" aria-hidden="true">
      <table class="spa-tech__table">
        <tr><td>Total Jets</td><td>{{ s.total_jets }}</td></tr>
        <tr><td>Hydrotherapy Jets</td><td>{{ s.hydro_jets }}</td></tr>
        <tr><td>Air Jets</td><td>{{ s.air_jets }}</td></tr>
        <tr><td>Massage Pumps</td><td>{{ s.massage_pumps }}</td></tr>
        <tr><td>Filtration Pump</td><td>{{ s.filtration_pump }}</td></tr>
        <tr><td>Electrical</td><td>{{ s.electrical }}</td></tr>
      </table>
    </div>

    <div class="spa-tech__panel" id="tech-build-{{ section.id }}" role="tabpanel" aria-labelledby="ttab-build-{{ section.id }}" aria-hidden="true">
      <table class="spa-tech__table">
        <tr><td>Shell</td><td>{{ c.shell_material }}</td></tr>
        <tr><td>Frame</td><td>{{ c.frame }}</td></tr>
        <tr><td>Insulation</td><td>{{ c.insulation }}</td></tr>
        <tr><td>Heating</td><td>{{ c.heating }}</td></tr>
        <tr><td>Controls</td><td>{{ c.controls }}</td></tr>
      </table>
    </div>

    <div class="spa-tech__panel" id="tech-warr-{{ section.id }}" role="tabpanel" aria-labelledby="ttab-warr-{{ section.id }}" aria-hidden="true">
      <table class="spa-tech__table">
        <tr><td>Structure</td><td>{{ w.structure_years }} years</td></tr>
        <tr><td>Surface</td><td>{{ w.surface_years }} years</td></tr>
        <tr><td>Equipment</td><td>{{ w.equipment_years }} years</td></tr>
      </table>
      {%- if certs -%}
        <table class="spa-tech__table" style="margin-top:1rem">
          {%- for cert in certs -%}
            <tr><td>Certification</td><td>{{ cert }}</td></tr>
          {%- endfor -%}
        </table>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    var sec = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sec) return;
    var tabs = sec.querySelectorAll('[role="tab"]');
    var panels = sec.querySelectorAll('[role="tabpanel"]');
    function activate(tab) {
      tabs.forEach(function(t) { t.setAttribute('aria-selected','false'); t.setAttribute('tabindex','-1'); });
      panels.forEach(function(p) { p.setAttribute('aria-hidden','true'); });
      tab.setAttribute('aria-selected','true');
      tab.setAttribute('tabindex','0');
      tab.focus();
      var p = sec.querySelector('#' + tab.getAttribute('aria-controls'));
      if (p) p.setAttribute('aria-hidden','false');
    }
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() { activate(tab); });
      tab.addEventListener('keydown', function(e) {
        var i = Array.prototype.indexOf.call(tabs, tab);
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); activate(tabs[(i+1) % tabs.length]); }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); activate(tabs[(i-1+tabs.length) % tabs.length]); }
        if (e.key === 'Home') { e.preventDefault(); activate(tabs[0]); }
        if (e.key === 'End') { e.preventDefault(); activate(tabs[tabs.length-1]); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Spa Technology",
  "tag": "section",
  "class": "shopify-section--spa-technology",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Technology"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineered without compromise."
    }
  ],
  "presets": [
    {
      "name": "Spa Technology"
    }
  ]
}
{% endschema %}
