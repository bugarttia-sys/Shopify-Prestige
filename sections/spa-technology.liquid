{%- comment -%}
  SPA TECHNOLOGY — Proprietary technology showcase
  Uses: product.metafields.content.technology_story
        product.metafields.features.proprietary (list)
        product.metafields.media.technology
        product.metafields.construction.*
{%- endcomment -%}

{%- liquid
  assign tech_story = product.metafields.content.technology_story.value
  assign tech_img = product.metafields.media.technology.value | default: product.featured_image
  assign proprietary = product.metafields.features.proprietary.value
  assign construction = product.metafields.construction
-%}

<style>
  #shopify-section-{{ section.id }} .spa-tech {
    padding: clamp(3rem, 5vw, 5rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-tech__container {
    max-width: var(--container-lg-max-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--container-gutter, 1.25rem);
  }

  /* --- Hero block: full-width image with overlay text --- */
  #shopify-section-{{ section.id }} .spa-tech__hero {
    position: relative;
    border-radius: var(--gms-radius, 2px);
    overflow: hidden;
    margin-bottom: clamp(3rem, 4vw, 4rem);
    min-height: 50vh;
    display: grid;
    place-items: end start;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-media {
    position: absolute;
    inset: 0;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(0,0,0,0.70) 0%, rgba(0,0,0,0.30) 45%, transparent 72%),
      linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-content {
    position: relative;
    z-index: 2;
    padding: clamp(2rem, 4vw, 3.5rem);
    max-width: 560px;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-heading {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__hero-body {
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1.7;
    opacity: 0.82;
    max-width: 46ch;
    margin: 0;
  }

  /* --- Proprietary features pills --- */
  #shopify-section-{{ section.id }} .spa-tech__features {
    text-align: center;
    margin-bottom: clamp(3rem, 4vw, 4rem);
  }

  #shopify-section-{{ section.id }} .spa-tech__features-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-tech__pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.5em 1.2em;
    border: 1px solid var(--gms-gold, #C68A1F);
    color: var(--gms-gold, #C68A1F);
    border-radius: 100px;
    letter-spacing: 0.01em;
    transition: all 0.35s ease;
  }

  #shopify-section-{{ section.id }} .spa-tech__pill:hover {
    background: var(--gms-gold, #C68A1F);
    color: #fff;
  }

  /* --- Construction grid --- */
  #shopify-section-{{ section.id }} .spa-tech__construction {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    padding-top: clamp(2rem, 3vw, 3rem);
    border-top: 1px solid var(--gms-border, rgba(0,0,0,0.06));
  }

  #shopify-section-{{ section.id }} .spa-tech__construct-item {
    text-align: center;
    padding: 1rem 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__construct-icon {
    margin-bottom: 0.75rem;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .spa-tech__construct-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.55;
    margin: 0 0 0.35rem;
  }

  #shopify-section-{{ section.id }} .spa-tech__construct-value {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-tech__hero {
      min-height: 40vh;
    }

    #shopify-section-{{ section.id }} .spa-tech__hero::after {
      background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.25) 55%, transparent 100%);
    }

    #shopify-section-{{ section.id }} .spa-tech__pill {
      font-size: 0.72rem;
      padding: 0.4em 0.9em;
    }

    #shopify-section-{{ section.id }} .spa-tech__construction {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<section class="spa-tech" aria-label="Technology and construction">
  <div class="spa-tech__container">

    {%- comment -%} Technology hero banner {%- endcomment -%}
    <div class="spa-tech__hero">
      <div class="spa-tech__hero-media">
        {%- if tech_img != blank -%}
          {{ tech_img | image_url: width: tech_img.width | image_tag: loading: 'lazy', sizes: '100vw', widths: '600,900,1200,1600,2000,2400', alt: product.title | append: ' technology' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
        {%- endif -%}
      </div>
      <div class="spa-tech__hero-content">
        <p class="spa-tech__hero-label">{{ section.settings.label | default: 'Proprietary Technology' }}</p>
        <h2 class="spa-tech__hero-heading">{{ section.settings.heading | default: 'Engineered exclusively by Passion Spas.' }}</h2>
        {%- if tech_story != blank -%}
          <p class="spa-tech__hero-body">{{ tech_story | truncatewords: 50 }}</p>
        {%- else -%}
          <p class="spa-tech__hero-body">Award-winning innovations that exist nowhere else in the industry.</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Proprietary features {%- endcomment -%}
    {%- if proprietary != blank and proprietary.size > 0 -%}
      <div class="spa-tech__features">
        <p class="spa-tech__features-label">Patented & Proprietary</p>
        <ul class="spa-tech__pills">
          {%- for p in proprietary -%}
            <li class="spa-tech__pill">{{ p }}</li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- comment -%} Construction at a glance {%- endcomment -%}
    {%- if construction.shell_material != blank -%}
      <div class="spa-tech__construction">
        <div class="spa-tech__construct-item">
          <div class="spa-tech__construct-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M2 12h20"/></svg>
          </div>
          <p class="spa-tech__construct-title">Shell</p>
          <p class="spa-tech__construct-value">{{ construction.shell_material }}</p>
        </div>
        <div class="spa-tech__construct-item">
          <div class="spa-tech__construct-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>
          </div>
          <p class="spa-tech__construct-title">Frame</p>
          <p class="spa-tech__construct-value">{{ construction.frame }}</p>
        </div>
        <div class="spa-tech__construct-item">
          <div class="spa-tech__construct-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <p class="spa-tech__construct-title">Heating</p>
          <p class="spa-tech__construct-value">{{ construction.heating }}</p>
        </div>
        <div class="spa-tech__construct-item">
          <div class="spa-tech__construct-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 16l4-4 4 4 5-5"/></svg>
          </div>
          <p class="spa-tech__construct-title">Insulation</p>
          <p class="spa-tech__construct-value">{{ construction.insulation }}</p>
        </div>
        <div class="spa-tech__construct-item">
          <div class="spa-tech__construct-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <p class="spa-tech__construct-title">Controls</p>
          <p class="spa-tech__construct-value">{{ construction.controls }}</p>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Spa Technology",
  "tag": "section",
  "class": "shopify-section--spa-technology",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Proprietary Technology"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero heading",
      "default": "Engineered exclusively by Passion Spas."
    }
  ],
  "presets": [
    {
      "name": "Spa Technology"
    }
  ]
}
{% endschema %}
