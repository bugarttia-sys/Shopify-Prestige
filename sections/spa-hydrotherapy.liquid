{%- comment -%}
  SPA HYDROTHERAPY — Experience & Benefits (dark-themed immersive)
  Anchored as #spa-hydrotherapy
  Uses: product.metafields.specs.* / features.* / pump.*
{%- endcomment -%}

{%- liquid
  assign specs = product.metafields.specs
  assign comfort = product.metafields.features.comfort.value
  assign energy = product.metafields.features.energy.value
  assign sanitation = product.metafields.features.sanitation.value
  assign entertainment = product.metafields.features.entertainment.value
  assign lighting = product.metafields.features.lighting.value
  assign optional = product.metafields.features.optional.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-hydro {
    background: var(--gms-charcoal, #1A1A1A);
    color: #fff;
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .spa-hydro__header {
    text-align: center;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 4vw, 3rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-hydro__eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-hydro__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 200;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-hydro__heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--gms-gold, #C68A1F);
    margin: 1.25rem auto 0;
  }

  /* ── Hero stat ── */
  #shopify-section-{{ section.id }} .spa-hydro__stat {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 0.75rem;
    padding: clamp(2.5rem, 4vw, 4rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-hydro__stat-number {
    font-size: clamp(4rem, 8vw, 7rem);
    font-weight: 100;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--gms-gold, #C68A1F);
  }

  #shopify-section-{{ section.id }} .spa-hydro__stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.4;
  }

  /* ── Feature rows ── */
  #shopify-section-{{ section.id }} .spa-hydro__rows {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem) clamp(4rem, 6vw, 6rem);
  }

  #shopify-section-{{ section.id }} .spa-hydro__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
    padding: clamp(2rem, 3vw, 3rem) 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  #shopify-section-{{ section.id }} .spa-hydro__row:first-child {
    border-top: none;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row--reverse {
    direction: rtl;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row--reverse > * {
    direction: ltr;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-media {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-media img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-content {
    max-width: 440px;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-eyebrow {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-heading {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 200;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-hydro__row-body {
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.8;
    opacity: 0.6;
    margin: 0 0 1rem;
  }

  /* ── Pills ── */
  #shopify-section-{{ section.id }} .spa-hydro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-hydro__pill {
    font-size: 0.7rem;
    font-weight: 400;
    padding: 0.35em 0.9em;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    transition: border-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .spa-hydro__pill:hover {
    border-color: rgba(255,255,255,0.35);
  }

  #shopify-section-{{ section.id }} .spa-hydro__upgrade {
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.3;
    margin: 1rem 0 0.4rem;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-hydro__row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    #shopify-section-{{ section.id }} .spa-hydro__row--reverse {
      direction: ltr;
    }
  }
</style>

<section class="spa-hydro" id="spa-hydrotherapy" aria-label="Hydrotherapy experience">
  <div class="spa-hydro__header">
    <p class="spa-hydro__eyebrow">{{ section.settings.eyebrow | default: 'Hydrotherapy' }}</p>
    <h2 class="spa-hydro__heading">{{ section.settings.heading | default: 'Precision-engineered relief.' }}</h2>
  </div>

  {%- comment -%} Hero jet count stat {%- endcomment -%}
  <div class="spa-hydro__stat">
    <span class="spa-hydro__stat-number">{{ specs.total_jets.value | default: '170' }}</span>
    <span class="spa-hydro__stat-label">Precision Jets</span>
  </div>

  <div class="spa-hydro__rows">
    {%- comment -%} Row 1: Jet System {%- endcomment -%}
    <div class="spa-hydro__row">
      <div class="spa-hydro__row-media">
        {%- assign hydro_img = product.metafields.media.hydrotherapy.value | default: product.featured_image -%}
        {%- if hydro_img != blank -%}
          {{ hydro_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000', alt: 'Hydrotherapy system' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="spa-hydro__row-content">
        <p class="spa-hydro__row-eyebrow">Jet System</p>
        <h3 class="spa-hydro__row-heading">Targeted relief. Total relaxation.</h3>
        <p class="spa-hydro__row-body">{{ specs.total_jets.value }} precision jets powered by {{ specs.massage_pumps.value | default: product.metafields.pump.massage.value }} massage pumps deliver targeted hydrotherapy to every seat.</p>
        {%- if comfort -%}
          <ul class="spa-hydro__pills">{%- for c in comfort -%}<li class="spa-hydro__pill">{{ c }}</li>{%- endfor -%}</ul>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Row 2: Energy (reversed) {%- endcomment -%}
    <div class="spa-hydro__row spa-hydro__row--reverse">
      <div class="spa-hydro__row-media">
        {%- assign energy_img = product.metafields.media.energy.value | default: product.featured_image -%}
        {%- if energy_img != blank -%}
          {{ energy_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000', alt: 'Energy management' }}
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="spa-hydro__row-content">
        <p class="spa-hydro__row-eyebrow">Energy Management</p>
        <h3 class="spa-hydro__row-heading">Intelligent insulation. Minimal running costs.</h3>
        {%- if energy -%}
          <ul class="spa-hydro__pills">{%- for e in energy -%}<li class="spa-hydro__pill">{{ e }}</li>{%- endfor -%}</ul>
        {%- endif -%}
        {%- if optional -%}
          <p class="spa-hydro__upgrade">Optional upgrades</p>
          <ul class="spa-hydro__pills">{%- for o in optional -%}<li class="spa-hydro__pill">{{ o }}</li>{%- endfor -%}</ul>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Row 3: Water Care {%- endcomment -%}
    <div class="spa-hydro__row">
      <div class="spa-hydro__row-media">
        {%- assign water_img = product.metafields.media.water_care.value | default: product.featured_image -%}
        {%- if water_img != blank -%}
          {{ water_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000', alt: 'Water care' }}
        {%- else -%}
          {{ 'product-3' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="spa-hydro__row-content">
        <p class="spa-hydro__row-eyebrow">Water Care</p>
        <h3 class="spa-hydro__row-heading">Crystal clear. Minimal effort.</h3>
        {%- if sanitation -%}
          <ul class="spa-hydro__pills">{%- for s in sanitation -%}<li class="spa-hydro__pill">{{ s }}</li>{%- endfor -%}</ul>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Row 4: Entertainment (reversed) {%- endcomment -%}
    {%- if entertainment or lighting -%}
      <div class="spa-hydro__row spa-hydro__row--reverse">
        <div class="spa-hydro__row-media">
          {%- assign ent_img = product.metafields.media.entertainment.value | default: product.featured_image -%}
          {%- if ent_img != blank -%}
            {{ ent_img | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 700px) 50vw, 100vw', widths: '400,600,800,1000', alt: 'Entertainment' }}
          {%- else -%}
            {{ 'product-4' | placeholder_svg_tag: 'placeholder' }}
          {%- endif -%}
        </div>
        <div class="spa-hydro__row-content">
          <p class="spa-hydro__row-eyebrow">Ambiance</p>
          <h3 class="spa-hydro__row-heading">Set the mood. Set the scene.</h3>
          {%- if lighting -%}
            <ul class="spa-hydro__pills">{%- for l in lighting -%}<li class="spa-hydro__pill">{{ l }}</li>{%- endfor -%}</ul>
          {%- endif -%}
          {%- if entertainment -%}
            <ul class="spa-hydro__pills" style="margin-top:0.5rem">{%- for e in entertainment -%}<li class="spa-hydro__pill">{{ e }}</li>{%- endfor -%}</ul>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Spa Hydrotherapy",
  "tag": "section",
  "class": "shopify-section--spa-hydrotherapy",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Hydrotherapy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Precision-engineered relief."
    }
  ],
  "presets": [
    {
      "name": "Spa Hydrotherapy"
    }
  ]
}
{% endschema %}
