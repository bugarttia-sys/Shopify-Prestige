{%- comment -%}
  SPA FAQ — Accordion FAQ with JSON-LD structured data
  Uses: product.metafields.content.faqs (json list of {q, a} objects)
{%- endcomment -%}

{%- liquid
  assign faqs = product.metafields.content.faqs.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-faq {
    padding: clamp(3rem, 5vw, 5rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-faq__container {
    max-width: var(--container-sm-max-width, 700px);
    margin-inline: auto;
    padding-inline: var(--container-gutter, 1.25rem);
  }

  #shopify-section-{{ section.id }} .spa-faq__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  #shopify-section-{{ section.id }} .spa-faq__heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-faq__item {
    border-bottom: 1px solid var(--gms-border, rgba(0,0,0,0.06));
  }

  #shopify-section-{{ section.id }} .spa-faq__question {
    cursor: pointer;
    padding: 1.15rem 2rem 1.15rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    position: relative;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .spa-faq__question::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .spa-faq__question::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--gms-mid-grey, #6B7280);
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .spa-faq__item[open] .spa-faq__question::after {
    content: '\2212';
  }

  #shopify-section-{{ section.id }} .spa-faq__answer {
    padding: 0 0 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-faq__answer p {
    font-size: 0.875rem;
    line-height: 1.7;
    opacity: 0.75;
    margin: 0;
  }
</style>

{%- if faqs != blank and faqs.size > 0 -%}
  <section class="spa-faq" aria-label="Frequently asked questions">
    <div class="spa-faq__container">
      <div class="spa-faq__header">
        <h2 class="spa-faq__heading">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
      </div>

      <div class="spa-faq__list">
        {%- for faq in faqs -%}
          <details class="spa-faq__item">
            <summary class="spa-faq__question">{{ faq.q }}</summary>
            <div class="spa-faq__answer">
              <p>{{ faq.a }}</p>
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} FAQ structured data for SEO {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for faq in faqs -%}
          {
            "@type": "Question",
            "name": {{ faq.q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ faq.a | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- else -%}
  {%- if request.design_mode -%}
    <section class="spa-faq" aria-label="Frequently asked questions">
      <div class="spa-faq__container">
        <div class="spa-faq__header">
          <h2 class="spa-faq__heading">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
        </div>
        <p style="text-align:center;opacity:0.5;font-size:0.875rem">Add FAQ data to product metafield <code>content.faqs</code> as JSON list of {q, a} objects.</p>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Spa FAQ",
  "tag": "section",
  "class": "shopify-section--spa-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "presets": [
    {
      "name": "Spa FAQ"
    }
  ]
}
{% endschema %}
