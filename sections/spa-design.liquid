{%- comment -%}
  SPA DESIGN — Design & Craftsmanship showcase with configurator
  Anchored as #spa-design in the page nav
  Uses: product.metafields.design.shell_colors (json)
        product.metafields.design.cabinet_finishes (json)
        product.metafields.media.design_default
{%- endcomment -%}

{%- liquid
  assign shell_colors = product.metafields.design.shell_colors.value
  assign cabinets = product.metafields.design.cabinet_finishes.value
  assign default_img = product.metafields.media.design_default.value | default: product.featured_image
-%}

<style>
  #shopify-section-{{ section.id }} .spa-design {
    background: #f7f7f7;
    color: var(--gms-charcoal, #1A1A1A);
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .spa-design__header {
    text-align: center;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 4vw, 4rem);
  }

  #shopify-section-{{ section.id }} .spa-design__eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gms-gold, #C68A1F);
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .spa-design__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 200;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-design__heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--gms-gold, #C68A1F);
    margin: 1.25rem auto 0;
  }

  /* ── Configurator layout ── */
  #shopify-section-{{ section.id }} .spa-design__config {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem) clamp(4rem, 6vw, 6rem);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ── Preview ── */
  #shopify-section-{{ section.id }} .spa-design__preview {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #eee;
  }

  #shopify-section-{{ section.id }} .spa-design__preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s ease;
  }

  #shopify-section-{{ section.id }} .spa-design__preview-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: rgba(0,0,0,0.75);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5em 1em;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* ── Controls ── */
  #shopify-section-{{ section.id }} .spa-design__controls {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  #shopify-section-{{ section.id }} .spa-design__group-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-design__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .spa-design__swatch-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  #shopify-section-{{ section.id }} .spa-design__swatch {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid transparent;
    padding: 0;
    background: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .spa-design__swatch-fill {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 3px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
  }

  #shopify-section-{{ section.id }} .spa-design__swatch:hover {
    transform: scale(1.1);
  }

  #shopify-section-{{ section.id }} .spa-design__swatch[aria-selected="true"] {
    border-color: var(--gms-gold, #C68A1F);
  }

  #shopify-section-{{ section.id }} .spa-design__swatch-name {
    font-size: 0.62rem;
    opacity: 0.5;
    letter-spacing: 0.02em;
  }

  /* ── Summary ── */
  #shopify-section-{{ section.id }} .spa-design__summary {
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  #shopify-section-{{ section.id }} .spa-design__summary-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    font-size: 0.82rem;
  }

  #shopify-section-{{ section.id }} .spa-design__summary-label {
    opacity: 0.4;
    font-weight: 300;
  }

  #shopify-section-{{ section.id }} .spa-design__summary-value {
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-design__config {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .spa-design__swatch {
      width: 40px;
      height: 40px;
    }
  }
</style>

<section class="spa-design" id="spa-design" aria-label="Design and configuration">
  <div class="spa-design__header">
    <p class="spa-design__eyebrow">{{ section.settings.eyebrow | default: 'Design & Craftsmanship' }}</p>
    <h2 class="spa-design__heading">{{ section.settings.heading | default: 'Make it yours.' }}</h2>
  </div>

  <div class="spa-design__config" id="spa-configure">
    <div class="spa-design__preview">
      {%- if default_img != blank -%}
        {{ default_img | image_url: width: 1200 | image_tag: loading: 'lazy', id: 'spa-design-img-' | append: section.id, sizes: '(min-width: 700px) 60vw, 100vw', widths: '400,600,800,1000,1200', alt: product.title | append: ' configuration' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
      <span class="spa-design__preview-badge" id="spa-design-badge-{{ section.id }}">Select a finish</span>
    </div>

    <div class="spa-design__controls">
      {%- if shell_colors != blank and shell_colors.size > 0 -%}
        <div>
          <p class="spa-design__group-label">Shell Colour</p>
          <div class="spa-design__swatches" role="radiogroup" aria-label="Shell colour">
            {%- for color in shell_colors -%}
              <div class="spa-design__swatch-wrap">
                <button class="spa-design__swatch" role="radio" aria-selected="false" aria-label="{{ color.name }}" data-type="shell" data-name="{{ color.name }}" {%- if color.image %}data-image="{{ color.image | image_url: width: 1200 }}"{% endif %}>
                  <span class="spa-design__swatch-fill" style="background:{{ color.hex | default: '#ccc' }}"></span>
                </button>
                <span class="spa-design__swatch-name">{{ color.name }}</span>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if cabinets != blank and cabinets.size > 0 -%}
        <div>
          <p class="spa-design__group-label">Cabinet Finish</p>
          <div class="spa-design__swatches" role="radiogroup" aria-label="Cabinet finish">
            {%- for cab in cabinets -%}
              <div class="spa-design__swatch-wrap">
                <button class="spa-design__swatch" role="radio" aria-selected="false" aria-label="{{ cab.name }}" data-type="cabinet" data-name="{{ cab.name }}" {%- if cab.image %}data-image="{{ cab.image | image_url: width: 1200 }}"{% endif %}>
                  <span class="spa-design__swatch-fill" style="background:{{ cab.hex | default: '#8B7355' }}"></span>
                </button>
                <span class="spa-design__swatch-name">{{ cab.name }}</span>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <div class="spa-design__summary">
        <div class="spa-design__summary-row">
          <span class="spa-design__summary-label">Shell</span>
          <span class="spa-design__summary-value" id="spa-design-shell-{{ section.id }}">—</span>
        </div>
        <div class="spa-design__summary-row">
          <span class="spa-design__summary-label">Cabinet</span>
          <span class="spa-design__summary-value" id="spa-design-cabinet-{{ section.id }}">—</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var s = document.querySelector('#shopify-section-{{ section.id }}');
    if (!s) return;
    var img = s.querySelector('#spa-design-img-{{ section.id }}');
    var badge = s.querySelector('#spa-design-badge-{{ section.id }}');
    var shellVal = s.querySelector('#spa-design-shell-{{ section.id }}');
    var cabVal = s.querySelector('#spa-design-cabinet-{{ section.id }}');

    s.querySelectorAll('.spa-design__swatch').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var group = btn.closest('[role="radiogroup"]');
        group.querySelectorAll('[role="radio"]').forEach(function(r) { r.setAttribute('aria-selected','false'); });
        btn.setAttribute('aria-selected','true');
        if (btn.dataset.image && img) { img.src = btn.dataset.image; img.srcset = ''; }
        if (badge) badge.textContent = btn.dataset.name;
        if (btn.dataset.type === 'shell' && shellVal) shellVal.textContent = btn.dataset.name;
        if (btn.dataset.type === 'cabinet' && cabVal) cabVal.textContent = btn.dataset.name;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Spa Design",
  "tag": "section",
  "class": "shopify-section--spa-design",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Design & Craftsmanship"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Make it yours."
    }
  ],
  "presets": [
    {
      "name": "Spa Design"
    }
  ]
}
{% endschema %}
