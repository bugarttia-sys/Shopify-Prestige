{%- comment -%}
  SPA SPECS — Tabbed technical specifications
  Uses: product.metafields.specs.*
        product.metafields.construction.*
        product.metafields.warranty.*
        product.metafields.product.certifications
{%- endcomment -%}

{%- liquid
  assign s = product.metafields.specs
  assign c = product.metafields.construction
  assign w = product.metafields.warranty
  assign certs = product.metafields.product.certifications.value
-%}

<style>
  #shopify-section-{{ section.id }} .spa-specs {
    padding: clamp(3rem, 5vw, 5rem) 0;
  }

  #shopify-section-{{ section.id }} .spa-specs__container {
    max-width: var(--container-lg-max-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--container-gutter, 1.25rem);
  }

  #shopify-section-{{ section.id }} .spa-specs__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  #shopify-section-{{ section.id }} .spa-specs__heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spa-specs__tabs {
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 1px solid var(--gms-border, rgba(0,0,0,0.06));
    margin-bottom: 2rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #shopify-section-{{ section.id }} .spa-specs__tab {
    padding: 0.85rem 1.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    opacity: 0.5;
    transition: all 0.35s ease;
    white-space: nowrap;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .spa-specs__tab:hover {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .spa-specs__tab[aria-selected="true"] {
    opacity: 1;
    border-bottom-color: var(--gms-gold, #C68A1F);
  }

  #shopify-section-{{ section.id }} .spa-specs__panel {
    display: none;
    max-width: 640px;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .spa-specs__panel[aria-hidden="false"] {
    display: block;
  }

  #shopify-section-{{ section.id }} .spa-specs__table {
    width: 100%;
    border-collapse: collapse;
  }

  #shopify-section-{{ section.id }} .spa-specs__table tr {
    border-bottom: 1px solid var(--gms-border, rgba(0,0,0,0.06));
    transition: background-color 0.35s ease;
  }

  #shopify-section-{{ section.id }} .spa-specs__table tr:hover {
    background-color: rgba(0, 0, 0, 0.015);
  }

  #shopify-section-{{ section.id }} .spa-specs__table td {
    padding: 0.65rem 0;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .spa-specs__table td:first-child {
    font-weight: 500;
    opacity: 0.65;
    width: 50%;
    padding-right: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-specs__table td:last-child {
    text-align: right;
    font-weight: 500;
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-specs__tabs {
      justify-content: flex-start;
      padding-inline: 0.5rem;
    }

    #shopify-section-{{ section.id }} .spa-specs__tab {
      padding: 0.75rem 1rem;
      font-size: 0.7rem;
    }
  }
</style>

<section class="spa-specs" aria-label="Technical specifications">
  <div class="spa-specs__container">
    <div class="spa-specs__header">
      <h2 class="spa-specs__heading">{{ section.settings.heading | default: 'Full Technical Specifications' }}</h2>
    </div>

    <div class="spa-specs__tabs" role="tablist">
      <button class="spa-specs__tab" role="tab" aria-selected="true" aria-controls="panel-dimensions-{{ section.id }}" id="tab-dimensions-{{ section.id }}" tabindex="0">Dimensions</button>
      <button class="spa-specs__tab" role="tab" aria-selected="false" aria-controls="panel-performance-{{ section.id }}" id="tab-performance-{{ section.id }}" tabindex="-1">Performance</button>
      <button class="spa-specs__tab" role="tab" aria-selected="false" aria-controls="panel-construction-{{ section.id }}" id="tab-construction-{{ section.id }}" tabindex="-1">Construction</button>
      <button class="spa-specs__tab" role="tab" aria-selected="false" aria-controls="panel-warranty-{{ section.id }}" id="tab-warranty-{{ section.id }}" tabindex="-1">Warranty</button>
    </div>

    <div class="spa-specs__panel" id="panel-dimensions-{{ section.id }}" role="tabpanel" aria-labelledby="tab-dimensions-{{ section.id }}" aria-hidden="false">
      <table class="spa-specs__table">
        <tr><td>Exterior Dimensions (L&times;W&times;H)</td><td>{{ s.length_cm }} &times; {{ s.width_cm }} &times; {{ s.height_cm }} cm</td></tr>
        <tr><td>Water Capacity</td><td>{{ s.water_capacity_liters }} liters</td></tr>
        <tr><td>Dry Weight</td><td>{{ s.dry_weight_kg }} kg</td></tr>
        <tr><td>Filled Weight</td><td>{{ s.filled_weight_kg }} kg</td></tr>
        <tr><td>Seating Capacity</td><td>{{ s.persons_capacity }} persons ({{ s.seats }} seats, {{ s.loungers }} loungers)</td></tr>
        {%- if s.has_lounger.value == true -%}
          <tr><td>Levitation Bed</td><td>Yes</td></tr>
        {%- endif -%}
      </table>
    </div>

    <div class="spa-specs__panel" id="panel-performance-{{ section.id }}" role="tabpanel" aria-labelledby="tab-performance-{{ section.id }}" aria-hidden="true">
      <table class="spa-specs__table">
        <tr><td>Total Jets</td><td>{{ s.total_jets }}</td></tr>
        <tr><td>Hydrotherapy Jets</td><td>{{ s.hydro_jets }}</td></tr>
        <tr><td>Air Jets</td><td>{{ s.air_jets }}</td></tr>
        <tr><td>Massage Pumps</td><td>{{ s.massage_pumps }}</td></tr>
        <tr><td>Filtration Pump</td><td>{{ s.filtration_pump }}</td></tr>
        <tr><td>Air Pump</td><td>{{ s.air_pump }}</td></tr>
        <tr><td>Electrical</td><td>{{ s.electrical }}</td></tr>
        <tr><td>Pillows</td><td>{{ s.pillows }}</td></tr>
      </table>
    </div>

    <div class="spa-specs__panel" id="panel-construction-{{ section.id }}" role="tabpanel" aria-labelledby="tab-construction-{{ section.id }}" aria-hidden="true">
      <table class="spa-specs__table">
        <tr><td>Shell Material</td><td>{{ c.shell_material }}</td></tr>
        <tr><td>Frame</td><td>{{ c.frame }}</td></tr>
        <tr><td>Insulation</td><td>{{ c.insulation }}</td></tr>
        <tr><td>Heating System</td><td>{{ c.heating }}</td></tr>
        <tr><td>Control System</td><td>{{ c.controls }}</td></tr>
      </table>
      {%- assign details = c.details.value -%}
      {%- if details -%}
        <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--gms-border, rgba(0,0,0,0.06))">
          <h4 style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;opacity:0.5;margin-bottom:0.6rem">Build Details</h4>
          <ul style="list-style:none;padding:0;margin:0">
            {%- for item in details -%}
              <li style="position:relative;padding:0.35rem 0 0.35rem 1.25rem;font-size:0.85rem;line-height:1.5">
                <span style="position:absolute;left:0;color:var(--gms-gold, #C68A1F);font-weight:700;font-size:0.75rem">&check;</span>
                {{ item }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>

    <div class="spa-specs__panel" id="panel-warranty-{{ section.id }}" role="tabpanel" aria-labelledby="tab-warranty-{{ section.id }}" aria-hidden="true">
      <table class="spa-specs__table">
        <tr><td>Structure</td><td>{{ w.structure_years }} years</td></tr>
        <tr><td>Surface</td><td>{{ w.surface_years }} years</td></tr>
        <tr><td>Equipment</td><td>{{ w.equipment_years }} years</td></tr>
      </table>
      {%- if certs -%}
        <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--gms-border, rgba(0,0,0,0.06))">
          <h4 style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;opacity:0.5;margin-bottom:0.6rem">Certifications</h4>
          <ul style="list-style:none;padding:0;margin:0">
            {%- for cert in certs -%}
              <li style="position:relative;padding:0.35rem 0 0.35rem 1.25rem;font-size:0.85rem;line-height:1.5">
                <span style="position:absolute;left:0;color:var(--gms-gold, #C68A1F);font-weight:700;font-size:0.75rem">&check;</span>
                {{ cert }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    const tabs = section.querySelectorAll('[role="tab"]');
    const panels = section.querySelectorAll('[role="tabpanel"]');

    function activateTab(tab) {
      tabs.forEach(function(t) { t.setAttribute('aria-selected', 'false'); t.setAttribute('tabindex', '-1'); });
      panels.forEach(function(p) { p.setAttribute('aria-hidden', 'true'); });

      tab.setAttribute('aria-selected', 'true');
      tab.setAttribute('tabindex', '0');
      tab.focus();
      var panel = section.querySelector('#' + tab.getAttribute('aria-controls'));
      if (panel) panel.setAttribute('aria-hidden', 'false');
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() { activateTab(tab); });
      tab.addEventListener('keydown', function(e) {
        var index = Array.prototype.indexOf.call(tabs, tab);
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); activateTab(tabs[(index + 1) % tabs.length]); }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); activateTab(tabs[(index - 1 + tabs.length) % tabs.length]); }
        if (e.key === 'Home') { e.preventDefault(); activateTab(tabs[0]); }
        if (e.key === 'End') { e.preventDefault(); activateTab(tabs[tabs.length - 1]); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Spa Specs",
  "tag": "section",
  "class": "shopify-section--spa-specs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Full Technical Specifications"
    }
  ],
  "presets": [
    {
      "name": "Spa Specs"
    }
  ]
}
{% endschema %}
