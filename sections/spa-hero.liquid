{%- comment -%}
  SPA HERO — Ultra-premium full-bleed hero with anchored section nav
  Inspired by luxury automotive page structure (centered content, gradient, anchor nav)
  Uses: product.metafields.media.hero_desktop / hero_mobile
        product.metafields.content.hero_tagline
        product.metafields.descriptors.subtitle
        product.metafields.custom.primary_cta
{%- endcomment -%}

{%- liquid
  assign hero_img    = product.metafields.media.hero_desktop.value | default: product.featured_image
  assign hero_mobile = product.metafields.media.hero_mobile.value
  assign tagline     = product.metafields.content.hero_tagline.value | default: product.metafields.descriptors.subtitle.value | default: 'The Ultimate Hydrotherapy Experience'
  assign cta_text    = product.metafields.custom.primary_cta.value | default: section.settings.cta_text
  assign cta_url     = section.settings.cta_url | default: '#spa-design'
  assign cta2_text   = section.settings.cta2_text
  assign cta2_url    = section.settings.cta2_url | default: '#spa-configure'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  /* ── HERO ── */
  #shopify-section-{{ section.id }} .spa-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    overflow: hidden;
    text-align: center;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .spa-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .spa-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .spa-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0,0,0,0.15) 0%,
      transparent 35%,
      rgba(0,0,0,calc(0.1 + var(--hero-overlay))) 65%,
      rgba(0,0,0,calc(0.5 + var(--hero-overlay))) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .spa-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 clamp(1.25rem, 4vw, 3rem) clamp(3rem, 8vw, 7rem);
    max-width: 800px;
  }

  #shopify-section-{{ section.id }} .spa-hero__brand {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .spa-hero__title {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 1rem;
  }

  #shopify-section-{{ section.id }} .spa-hero__tagline {
    font-size: clamp(0.95rem, 1.3vw, 1.15rem);
    font-weight: 300;
    opacity: 0.7;
    max-width: 40ch;
    margin: 0 auto 2rem;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .spa-hero__actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  #shopify-section-{{ section.id }} .spa-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9em 2.4em;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .spa-hero__btn--solid {
    background: #fff;
    color: var(--gms-charcoal, #1A1A1A);
    border: 1px solid #fff;
  }

  #shopify-section-{{ section.id }} .spa-hero__btn--solid:hover {
    background: transparent;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .spa-hero__btn--outline {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
  }

  #shopify-section-{{ section.id }} .spa-hero__btn--outline:hover {
    border-color: #fff;
  }

  /* ── SCROLL INDICATOR ── */
  #shopify-section-{{ section.id }} .spa-hero__scroll {
    position: relative;
    z-index: 2;
    padding-bottom: 2rem;
    opacity: 0.4;
    animation: spa-hero-pulse 2s ease-in-out infinite;
  }

  @keyframes spa-hero-pulse {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(6px); opacity: 0.7; }
  }

  /* ── ANCHOR NAV ── */
  #shopify-section-{{ section.id }} .spa-hero__nav {
    position: relative;
    z-index: 3;
    width: 100%;
    background: var(--gms-charcoal, #1A1A1A);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  #shopify-section-{{ section.id }} .spa-hero__nav-inner {
    display: flex;
    justify-content: center;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .spa-hero__nav-inner::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .spa-hero__nav-link {
    display: flex;
    align-items: center;
    padding: 1rem 1.5rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .spa-hero__nav-link:hover,
  #shopify-section-{{ section.id }} .spa-hero__nav-link:focus-visible {
    color: #fff;
    border-bottom-color: var(--gms-gold, #C68A1F);
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .spa-hero__title {
      font-size: 2.5rem;
    }

    #shopify-section-{{ section.id }} .spa-hero__actions {
      flex-direction: column;
      padding: 0 1rem;
    }

    #shopify-section-{{ section.id }} .spa-hero__btn {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .spa-hero__nav-link {
      padding: 0.85rem 1.1rem;
      font-size: 0.62rem;
    }
  }
</style>

<section class="spa-hero" aria-label="Product hero" {% if section.settings.allow_transparent_header %}allow-transparent-header{% endif %}>
  <div class="spa-hero__media">
    {%- if hero_img != blank -%}
      <picture>
        {%- if hero_mobile != blank -%}
          <source
            media="(max-width: 699px)"
            srcset="{{ hero_mobile | image_url: width: 400 }} 400w, {{ hero_mobile | image_url: width: 600 }} 600w, {{ hero_mobile | image_url: width: 800 }} 800w, {{ hero_mobile | image_url: width: 1000 }} 1000w"
            width="{{ hero_mobile.width }}"
            height="{{ hero_mobile.height }}"
          >
        {%- endif -%}
        {{ hero_img | image_url: width: hero_img.width | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', widths: '600,900,1200,1600,2000,2400,2800,3200', alt: product.title }}
      </picture>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
    {%- endif -%}
  </div>

  <div class="spa-hero__content">
    <p class="spa-hero__brand">{{ section.settings.brand_text | default: product.vendor }}</p>
    <h1 class="spa-hero__title">{{ product.title }}</h1>
    <p class="spa-hero__tagline">{{ tagline }}</p>

    <div class="spa-hero__actions">
      {%- if cta_text != blank -%}
        <a href="{{ cta_url }}" class="spa-hero__btn spa-hero__btn--solid">{{ cta_text }}</a>
      {%- endif -%}
      {%- if cta2_text != blank -%}
        <a href="{{ cta2_url }}" class="spa-hero__btn spa-hero__btn--outline">{{ cta2_text }}</a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Scroll indicator {%- endcomment -%}
  <div class="spa-hero__scroll" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </div>

  {%- comment -%} Anchored section navigation {%- endcomment -%}
  {%- if section.settings.show_nav -%}
    <nav class="spa-hero__nav" aria-label="Page sections">
      <div class="spa-hero__nav-inner">
        <a href="#spa-design" class="spa-hero__nav-link">Design</a>
        <a href="#spa-hydrotherapy" class="spa-hero__nav-link">Hydrotherapy</a>
        <a href="#spa-technology" class="spa-hero__nav-link">Technology</a>
        <a href="#spa-materials" class="spa-hero__nav-link">Construction</a>
        <a href="#spa-configure" class="spa-hero__nav-link">Configure</a>
      </div>
    </nav>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Spa Hero",
  "tag": "section",
  "class": "shopify-section--spa-hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "Allow transparent header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show anchor navigation bar",
      "default": true
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "GRAND MASTER SPAS"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA text",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Secondary CTA text",
      "default": "Configure & Price"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Spa Hero"
    }
  ]
}
{% endschema %}
